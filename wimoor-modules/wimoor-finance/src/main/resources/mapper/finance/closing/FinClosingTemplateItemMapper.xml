    </select>

    <insert id="insertFinClosingTemplateItem" parameterType="com.wimoor.finance.closing.domain.FinClosingTemplateItem" useGeneratedKeys="true" keyProperty="id">
        insert into fin_closing_template_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
