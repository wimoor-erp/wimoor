    <sql id="selectFinClosingTemplateItemVo">
        select id, closing_template_id, summary, subject_id, amount_field, direction, created_time, updated_time, modify_by, create_by from fin_closing_template_item
    </sql>

    <select id="selectFinClosingTemplateItemList" parameterType="com.wimoor.finance.closing.domain.FinClosingTemplateItem" resultMap="FinClosingTemplateItemResult">
        <include refid="selectFinClosingTemplateItemVo"/>
        <where>  
            <if test="closingTemplateId != null  and closingTemplateId != ''"> and closing_template_id = #{closingTemplateId}</if>
            <if test="summary != null  and summary != ''"> and summary = #{summary}</if>
            <if test="subjectId != null  and subjectId != ''"> and subject_id = #{subjectId}</if>
            <if test="amountField != null  and amountField != ''"> and amount_field = #{amountField}</if>
            <if test="createdTime != null "> and created_time = #{createdTime}</if>
            <if test="updatedTime != null "> and updated_time = #{updatedTime}</if>
            <if test="direction != null  and direction != ''"> and direction = #{direction}</if>
            <if test="modifyBy != null  and modifyBy != ''"> and modify_by = #{modifyBy}</if>
        </where>
    </select>
    
    <select id="selectFinClosingTemplateItemById" parameterType="String" resultMap="FinClosingTemplateItemResult">
        <include refid="selectFinClosingTemplateItemVo"/>
