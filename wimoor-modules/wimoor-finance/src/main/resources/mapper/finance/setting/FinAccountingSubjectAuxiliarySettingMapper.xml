<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wimoor.finance.setting.mapper.FinAccountingSubjectAuxiliarySettingMapper">
    
    <resultMap type="com.wimoor.finance.setting.domain.FinAccountingSubjectAuxiliarySetting" id="FinAccountingSubjectAuxiliarySettingResult">
        <result property="id"    column="id"    />
        <result property="subjectId"    column="subject_id"    />
        <result property="auxiliaryTypeId"    column="auxiliary_type_id"    />
        <result property="typeName"    column="type_name"    />
        <result property="typeCode"    column="type_code"    />
        <result property="groupid"    column="groupid"    />
        <result property="createdTime"    column="created_time"    />
        <result property="updatedTime"    column="updated_time"    />
    </resultMap>

    <sql id="selectFinAccountingSubjectAuxiliarySettingVo">
        select s.id, s.subject_id, s.auxiliary_type_id, t.type_name, t.type_code, s.groupid, s.created_time, s.updated_time 
        from fin_accounting_subject_auxiliary_setting s
        left join fin_auxiliary_types t on s.auxiliary_type_id = t.type_id
    </sql>

    <select id="selectFinAccountingSubjectAuxiliarySettingList" parameterType="com.wimoor.finance.setting.domain.FinAccountingSubjectAuxiliarySetting" resultMap="FinAccountingSubjectAuxiliarySettingResult">
        <include refid="selectFinAccountingSubjectAuxiliarySettingVo"/>
        <where>  
            <if test="subjectId != null  and subjectId != ''"> and subject_id = #{subjectId}</if>
            <if test="auxiliaryTypeId != null  and auxiliaryTypeId != ''"> and auxiliary_type_id = #{auxiliaryTypeId}</if>
            <if test="groupid != null  and groupid != ''"> and groupid = #{groupid}</if>
            <if test="createdTime != null "> and created_time = #{createdTime}</if>
            <if test="updatedTime != null "> and updated_time = #{updatedTime}</if>
        </where>
    </select>
    
    <select id="selectFinAccountingSubjectAuxiliarySettingById" parameterType="String" resultMap="FinAccountingSubjectAuxiliarySettingResult">
        <include refid="selectFinAccountingSubjectAuxiliarySettingVo"/>
        where id = #{id}
    </select>

    <insert id="insertFinAccountingSubjectAuxiliarySetting" parameterType="com.wimoor.finance.setting.domain.FinAccountingSubjectAuxiliarySetting" useGeneratedKeys="true" keyProperty="id">
        insert into fin_accounting_subject_auxiliary_setting
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="subjectId != null and subjectId != ''">subject_id,</if>
            <if test="auxiliaryTypeId != null and auxiliaryTypeId != ''">auxiliary_type_id,</if>
            <if test="groupid != null">groupid,</if>
            <if test="createdTime != null">created_time,</if>
            <if test="updatedTime != null">updated_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="subjectId != null and subjectId != ''">#{subjectId},</if>
            <if test="auxiliaryTypeId != null and auxiliaryTypeId != ''">#{auxiliaryTypeId},</if>
            <if test="groupid != null">#{groupid},</if>
            <if test="createdTime != null">#{createdTime},</if>
            <if test="updatedTime != null">#{updatedTime},</if>
         </trim>
    </insert>

    <update id="updateFinAccountingSubjectAuxiliarySetting" parameterType="com.wimoor.finance.setting.domain.FinAccountingSubjectAuxiliarySetting">
        update fin_accounting_subject_auxiliary_setting
        <trim prefix="SET" suffixOverrides=",">
            <if test="subjectId != null and subjectId != ''">subject_id = #{subjectId},</if>
            <if test="auxiliaryTypeId != null and auxiliaryTypeId != ''">auxiliary_type_id = #{auxiliaryTypeId},</if>
            <if test="groupid != null">groupid = #{groupid},</if>
            <if test="createdTime != null">created_time = #{createdTime},</if>
            <if test="updatedTime != null">updated_time = #{updatedTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteFinAccountingSubjectAuxiliarySettingById" parameterType="String">
        delete from fin_accounting_subject_auxiliary_setting where id = #{id}
    </delete>

    <delete id="deleteFinAccountingSubjectAuxiliarySettingByIds" parameterType="String">
        delete from fin_accounting_subject_auxiliary_setting where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>